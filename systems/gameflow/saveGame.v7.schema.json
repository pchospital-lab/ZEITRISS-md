{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://zeitriss.example/saveGame.v7.schema.json",
  "title": "ZEITRISS Save v7 (Import/Normalizer, tolerant)",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "v",
    "zr",
    "save_id",
    "parent_save_id",
    "merge_id",
    "branch_id",
    "campaign",
    "characters",
    "economy",
    "logs",
    "summaries",
    "continuity",
    "arc",
    "ui"
  ],
  "properties": {
    "v": {
      "type": "integer",
      "const": 7
    },
    "zr": {
      "type": "string"
    },
    "save_id": {
      "type": "string"
    },
    "parent_save_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "merge_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "branch_id": {
      "type": "string"
    },
    "campaign": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "episode",
        "mission",
        "px",
        "px_state",
        "mode",
        "rift_seeds"
      ],
      "properties": {
        "episode": {
          "type": "integer"
        },
        "mission": {
          "type": "integer"
        },
        "px": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "px_state": {
          "type": "string",
          "enum": [
            "stable",
            "pending_reset",
            "consumed"
          ]
        },
        "mode": {
          "type": "string",
          "enum": [
            "mixed",
            "preserve",
            "trigger"
          ]
        },
        "rift_seeds": {
          "type": "array"
        }
      }
    },
    "characters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "wallet"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "wallet": {
            "type": "number"
          },
          "level_history": {
            "description": "Pro-Character Level-Up-Historie. Key = Level als String ('1','2',...). Pflicht für Anti-Stacking-Gate (§F Level-Up-Exklusivitäts-Pflichtgate). Platzierung: character.level_history (NICHT Root-Ebene).",
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "required": [
                "choice"
              ],
              "properties": {
                "choice": {
                  "type": "string",
                  "enum": [
                    "+1 Attribut",
                    "Talent/Upgrade",
                    "+1 SYS"
                  ]
                },
                "detail": {
                  "type": "string"
                },
                "mission": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "economy": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "hq_pool"
      ],
      "properties": {
        "hq_pool": {
          "type": "number"
        }
      }
    },
    "logs": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "trace",
        "notes",
        "artifact_log",
        "market",
        "flags"
      ],
      "properties": {
        "flags": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "runtime_version": {
              "type": "string"
            },
            "chronopolis_unlocked": {
              "type": "boolean"
            },
            "imported_saves": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "duplicate_branch_detected": {
              "type": "boolean"
            },
            "duplicate_character_detected": {
              "type": "boolean"
            },
            "continuity_conflicts": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "char_id": {
                    "type": "string"
                  },
                  "anchor_save_id": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "incoming_save_id": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "resolution": {
                    "type": "string",
                    "enum": [
                      "anchor_kept_echo_imported",
                      "newer_personal_state_applied"
                    ]
                  },
                  "note": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "arc": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "factions",
        "questions",
        "hooks"
      ]
    },
    "ui": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "gm_style",
        "suggest_mode",
        "action_mode",
        "contrast",
        "badge_density",
        "output_pace",
        "voice_profile"
      ],
      "properties": {
        "action_mode": {
          "type": "string",
          "enum": [
            "uncut"
          ]
        }
      }
    },
    "arena": {
      "type": "object"
    },
    "loadout": {
      "type": "object"
    },
    "summaries": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "summary_last_episode",
        "summary_last_rift",
        "summary_active_arcs"
      ],
      "properties": {
        "summary_last_episode": {
          "type": "string"
        },
        "summary_last_rift": {
          "type": "string"
        },
        "summary_active_arcs": {
          "type": "string"
        }
      }
    },
    "continuity": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "last_seen": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "hq",
                "core",
                "rift",
                "arena",
                "chronopolis",
                "debrief"
              ]
            },
            "episode": {
              "type": "integer"
            },
            "mission": {
              "type": "integer"
            },
            "location": {
              "type": "string"
            }
          }
        },
        "split": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "family_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "thread_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "expected_threads": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "resolved_threads": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "convergence_ready": {
              "type": "boolean"
            }
          }
        },
        "roster_echoes": {
          "description": "Figuren-Echos aus Split/Merge. Jedes Item MUSS Objekt mit 'char_id' sein (Referenz auf characters[].id). NICHT mit shared_echoes-Format vermischen — roster_echoes bindet an Figur, shared_echoes an Ereignis. Siehe Masterprompt §D roster_echoes-Pflichtformat.",
          "type": "array",
          "maxItems": 5,
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "char_id"
            ],
            "properties": {
              "char_id": {
                "type": "string"
              },
              "tone": {
                "type": "string"
              },
              "text": {
                "type": "string"
              }
            }
          }
        },
        "shared_echoes": {
          "description": "Gruppen-Echos aus Split/Merge. Jedes Item MUSS Objekt mit 'tag' sein (Slug/Identifier), niemals Rohstring oder {echo: ...}. Siehe Masterprompt §D Split/Merge-Pflichtformat.",
          "type": "array",
          "maxItems": 6,
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "tag"
            ],
            "properties": {
              "tag": {
                "type": "string"
              },
              "scope": {
                "type": "string",
                "enum": [
                  "shared",
                  "rumor",
                  "campaign",
                  "personal"
                ]
              },
              "text": {
                "type": "string"
              }
            }
          }
        },
        "convergence_tags": {
          "type": "array",
          "maxItems": 4,
          "items": {
            "type": "string"
          }
        },
        "npc_roster": {
          "type": "array",
          "maxItems": 6,
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "active_npc_ids": {
          "type": "array",
          "maxItems": 4,
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "last_seen",
        "split",
        "roster_echoes",
        "shared_echoes",
        "convergence_tags",
        "npc_roster",
        "active_npc_ids"
      ]
    }
  },
  "description": "Tolerantes Import-/Normalizer-Schema für Legacy- und Join-Loads. Für kanonischen !save-Export gilt saveGame.v7.export.schema.json."
}
