{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://zeitriss.example/saveGame.v7.schema.json",
  "title": "ZEITRISS Save v7 (kanonischer Export)",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "v",
    "zr",
    "save_id",
    "parent_save_id",
    "merge_id",
    "branch_id",
    "campaign",
    "characters",
    "economy",
    "logs",
    "summaries",
    "continuity",
    "arc",
    "ui"
  ],
  "properties": {
    "v": {
      "type": "integer",
      "const": 7
    },
    "zr": {
      "type": "string"
    },
    "save_id": {
      "type": "string"
    },
    "parent_save_id": {
      "type": ["string", "null"]
    },
    "merge_id": {
      "type": ["string", "null"]
    },
    "branch_id": {
      "type": "string"
    },
    "campaign": {
      "type": "object",
      "additionalProperties": true,
      "required": ["episode", "mission", "px", "px_state"],
      "properties": {
        "episode": {
          "type": "integer"
        },
        "mission": {
          "type": "integer"
        },
        "px": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "px_state": {
          "type": "string",
          "enum": ["stable", "pending_reset", "consumed"]
        }
      }
    },
    "characters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "wallet"],
        "properties": {
          "id": {
            "type": "string"
          },
          "wallet": {
            "type": "number"
          }
        }
      }
    },
    "economy": {
      "type": "object",
      "additionalProperties": true,
      "required": ["hq_pool"],
      "properties": {
        "hq_pool": {
          "type": "number"
        }
      }
    },
    "logs": {
      "type": "object",
      "additionalProperties": true,
      "required": ["trace", "notes", "artifact_log", "market", "flags"],
      "properties": {
        "flags": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "runtime_version": {
              "type": "string"
            },
            "chronopolis_unlocked": {
              "type": "boolean"
            },
            "imported_saves": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "duplicate_branch_detected": {
              "type": "boolean"
            },
            "duplicate_character_detected": {
              "type": "boolean"
            },
            "continuity_conflicts": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "char_id": {
                    "type": "string"
                  },
                  "anchor_save_id": {
                    "type": ["string", "null"]
                  },
                  "incoming_save_id": {
                    "type": ["string", "null"]
                  },
                  "resolution": {
                    "type": "string",
                    "enum": ["anchor_kept_echo_imported", "newer_personal_state_applied"]
                  },
                  "note": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "arc": {
      "type": "object",
      "additionalProperties": true,
      "required": ["factions", "questions", "hooks"]
    },
    "ui": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "gm_style",
        "suggest_mode",
        "contrast",
        "badge_density",
        "output_pace",
        "voice_profile"
      ]
    },
    "arena": {
      "type": "object"
    },
    "loadout": {
      "type": "object"
    },
    "summaries": {
      "type": "object",
      "additionalProperties": true,
      "required": ["summary_last_episode", "summary_last_rift", "summary_active_arcs"],
      "properties": {
        "summary_last_episode": {
          "type": "string"
        },
        "summary_last_rift": {
          "type": "string"
        },
        "summary_active_arcs": {
          "type": "string"
        }
      }
    },
    "continuity": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "last_seen": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "mode": {
              "type": "string"
            },
            "episode": {
              "type": "integer"
            },
            "mission": {
              "type": "integer"
            },
            "location": {
              "type": "string"
            }
          }
        },
        "split": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "family_id": {
              "type": ["string", "null"]
            },
            "thread_id": {
              "type": ["string", "null"]
            },
            "expected_threads": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "resolved_threads": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "convergence_ready": {
              "type": "boolean"
            }
          }
        },
        "roster_echoes": {
          "type": "array",
          "maxItems": 5,
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "char_id": {
                "type": "string"
              },
              "tone": {
                "type": "string"
              },
              "text": {
                "type": "string"
              }
            }
          }
        },
        "shared_echoes": {
          "type": "array",
          "maxItems": 6,
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "tag": {
                "type": "string"
              },
              "scope": {
                "type": "string",
                "enum": ["shared", "rumor", "campaign", "personal"]
              },
              "text": {
                "type": "string"
              }
            }
          }
        },
        "convergence_tags": {
          "type": "array",
          "maxItems": 4,
          "items": {
            "type": "string"
          }
        },
        "npc_roster": {
          "type": "array",
          "maxItems": 6,
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "active_npc_ids": {
          "type": "array",
          "maxItems": 4,
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "last_seen",
        "split",
        "roster_echoes",
        "shared_echoes",
        "convergence_tags",
        "npc_roster",
        "active_npc_ids"
      ]
    }
  }
}
