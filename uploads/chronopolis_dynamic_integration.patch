@@ macro start_chronopolis(district="Agora", ep=None) -%>
-    set campaign.loc = 'CITY'
-    set chrono = {
-    'active': true, 'district': district, 'epoch': ep,
-    'price_mod': 1.0, 'black_mod': 1.3, 'phase': 'INIT',
-    'pressure': 0,
