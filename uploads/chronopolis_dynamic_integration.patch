+    set pick = force_type
+    if not pick:
+      # Build dynamic list of possible beat types.  Boss beats only appear
+      # once per Chronopolis run and draw from the last mission boss. Para beats
+      # depend on open rift seeds and have an 1/8 chance outside of psi/alarm events.
+      set possible = []
+      if chrono.boss and not chrono.boss_encountered:
+        do possible.append('boss')
+      endif
+      if chrono.open_seeds:
+        if event_tag in ['psi_tech','alarm']:
+          do possible.append('para')
+        elif rng_roll(1,8)[0][0] == 8:
+          do possible.append('para')
+        endif
+      endif
+      if chrono.big_win_seen and (chrono.pressure or 0) >= 3:
+        do possible.extend(['encounter','twist','encounter','encounter'])
+      else:
+        do possible.extend(['encounter','nsc','twist','encounter'])
+      endif
+      if possible|length == 0:
+        set possible = ['encounter']
+      endif
+      set pick = random.choice(possible)
+    endif
+    # Prevent back-to-back twists
+    if pick == chrono.last_beat_type and pick == 'twist':
+      set pick = 'encounter'
+    endif
+    set chrono.last_beat_type = pick
+    set chrono.phase = 'REACT'
+    if pick == 'boss':
+      # Encounter the last boss/mini-boss from the current episode; this counts
+      # as a big win to trigger exit pressure.
+      set beat = 'Du triffst auf ' ~ chrono.boss ~ ', gezeichnet von den letzten Ereignissen'
+      set chrono.boss_encountered = true
+      do chrono_mark_big_win('boss')
+    elif pick == 'para':
+      set seed = chrono.open_seeds | random
+      set para = generate_para_creature(seed)
+      # ``para.hud`` already contains a formatted HUD tag; fallback to name
+      set beat = para.hud or ('Para-Kreatur ' ~ para.creature.name)
+    elif pick == 'encounter':
+      set beat = random.choice(['Patrouille schneidet die Route','Blockade mit Scan-Fenster','Zeugen markieren eure Signatur','Exit-Jäger nehmen Fährte auf'])
+    elif pick == 'nsc':
+      set beat = random.choice(['Händler bietet überteuerte Abkürzung','Informantin verkauft halbe Wahrheit','Schieber kennt einen stillen Rückweg','Köderkontakt lockt in Engstelle'])
+    elif pick == 'twist':
+      set beat = random.choice(['Weg kippt in Sperrzone','Deal bricht im letzten Satz','Beobachter meldet euch weiter','Ware ist manipuliert'])
+    else:
+      set beat = random.choice(['Para-Schatten frisst Sensorbild','Urban-Myth kreuzt die Ringroute'])
+    endif
+    set chrono.last_beat = {'event': event_tag, 'type': pick, 'beat': beat, 'context': context}
+    hud_tag('Chronopolis-Beat [' ~ pick ~ '] nach ' ~ event_tag ~ ': ' ~ beat)
+    chrono_hud('REACT')
+    {% endmacro %}