-    'last_beat_type': None,
-    'last_beat': None
-    } %>
+    {# Use current campaign epoch when no epoch provided #}
+    set ep = ep or campaign.epoch
+    {# determine the last boss or mini-boss from mission history #}
+    set boss_name = None
+    if campaign.boss_history is defined and campaign.boss_history:
+      set boss_name = campaign.boss_history[-1]
+    endif
+    {# collect all open rift seeds for para beats #}
+    set open_seeds = []
+    for seed in (campaign.rift_seeds or []):
+      set status = (seed.status or 'open')|lower
+      if status != 'closed':
+        do open_seeds.append(seed)
+      endif
+    endfor
+    set campaign.loc = 'CITY'
+    set chrono = {
+    'active': true,
+    'district': district,
+    'epoch': ep,
+    'boss': boss_name,
+    'open_seeds': open_seeds,
+    'boss_encountered': false,
+    'price_mod': 1.0,
+    'black_mod': 1.3,
+    'phase': 'INIT',
+    'pressure': 0,
+    'big_win_seen': false,
+    'last_beat_type': None,
+    'last_beat': None
+    } %>
