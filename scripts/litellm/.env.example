# Kopiere diese Datei nach .env und trage Werte ein:
#   cp .env.example .env
#   chmod 600 .env
#
# Das Setup-Script (`python scripts/setup.py --install-litellm`) legt .env
# automatisch an. Diese Beispieldatei ist nur als Referenz gedacht,
# falls ihr LiteLLM manuell starten wollt.

# OpenRouter-API-Key. Bekommt man unter https://openrouter.ai/keys
# (Account erstellen, Guthaben aufladen, Key erzeugen).
# Wichtig: In den OpenRouter-Privacy-Settings muss Anthropic/Bedrock
# als Route zugelassen sein, sonst greift das Prompt-Caching nicht.
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# Beliebiger starker Zufalls-String, z. B. mit:
#   python -c "import secrets; print('sk-litellm-' + secrets.token_urlsafe(32))"
# Dient als Auth zwischen OpenWebUI und LiteLLM — ohne den Key
# nimmt der Proxy keine Requests an.
LITELLM_MASTER_KEY=sk-litellm-REPLACE_ME
